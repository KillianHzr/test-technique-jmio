<aside class="sidebar">
    <div class="sidebar__inner">
        <nav class="nav">
            <div class="nav-logo">
                {% include 'components/atoms/logo.html.twig' %}
            </div>
        </nav>
        
        <div class="hero-mini">
            <span class="hero-eyebrow">{{ hero_eyebrow|default('JEAN-MICHEL TROUVETOU'|trans) }}</span>
            <h1 class="hero-title">{{ hero_title|default('Trouvez votre <strong>talent.</strong>'|trans)|raw }}</h1>
        </div>

        <div class="search-panel">
            {% block sidebar_content %}{% endblock %}
        </div>

        <div class="sidebar__footer-actions">
            <div class="footer-row">
                <div class="footer-col">
                    <span class="footer-label">{{ 'LANGUE'|trans }}</span>
                    <div class="footer-controls">
                        <a href="{{ path('change_locale', {'locale': 'fr'}) }}" class="footer-link {% if app.request.locale == 'fr' %}active{% endif %}">FR</a>
                        <a href="{{ path('change_locale', {'locale': 'en'}) }}" class="footer-link {% if app.request.locale == 'en' %}active{% endif %}">EN</a>
                    </div>
                </div>
                <div class="footer-col">
                    <span class="footer-label">{{ 'COMPTE'|trans }}</span>
                    <div class="footer-controls">
                        {% if app.user %}
                            <a href="{{ path('app_recruiter_profile') }}" class="user-profile-badge" title="{{ 'Mon Profil'|trans }}">
                                {{ app.user.email|slice(0, 1)|upper }}
                            </a>
                            <a href="{{ path('app_logout') }}" class="btn-footer-icon btn-footer-icon--logout" title="{{ 'Déconnexion'|trans }}">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                            </a>
                        {% else %}
                            <a href="{{ path('app_login') }}" class="footer-link-login">
                                {{ 'CONNEXION'|trans }}
                            </a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>

        {% include 'components/molecules/sidebar_footer.html.twig' %}
    </div>
</aside>