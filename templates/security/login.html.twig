{% extends 'base.html.twig' %}

{% block title %}{{ 'Log in!'|trans }}{% endblock %}

{% block body %}
<div class="app-shell app-shell--reverse">
    {% embed 'components/organisms/sidebar.html.twig' with {
        'hero_eyebrow': 'RECRUITER ACCESS'|trans,
        'hero_title': 'Espace <strong>Recruteur.</strong>'|trans
    } %}
        {% block sidebar_content %}
            <a href="{{ path('home') }}" class="btn-back-app">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <path d="M19 12H5M12 19l-7-7 7-7"/>
                </svg>
                {{ "RETOUR À L'APP"|trans }}
            </a>
        {% endblock %}
    {% endembed %}

    <main class="main-view">
        <div class="main-view__scroll-zone flex-center-full">
            <div class="auth-card">
                <form method="post">
                    {% if error %}
                        <div class="alert-error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                    {% endif %}

                    <h1 class="auth-title">{{ 'Connexion'|trans }}</h1>
                    
                    <div class="form-group">
                        <label for="inputEmail">{{ 'Email'|trans }}</label>
                        <input type="email" value="{{ last_username }}" name="email" id="inputEmail" class="form-control" autocomplete="email" required autofocus>
                    </div>
                    
                    <div class="form-group">
                        <label for="inputPassword">{{ 'Mot de passe'|trans }}</label>
                        <input type="password" name="password" id="inputPassword" class="form-control" autocomplete="current-password" required>
                    </div>

                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                    <button class="btn-auth" type="submit">
                        {{ 'SE CONNECTER'|trans }}
                    </button>
                </form>
                
                <p class="auth-footer">{{ "Pas encore de compte ? Contactez Jean-Michel."|trans }}</p>
                <div class="auth-demo-hint">
                    <strong>Demo:</strong> recruteur@jean-michel.io / password
                </div>
            </div>
        </div>
    </main>
</div>
{% endblock %}
