{% extends 'base.html.twig' %}

{% block title %}Page introuvable — jean-michel.io{% endblock %}

{% block body %}
<div class="error-view">
    <div class="error-card">
        <div class="error-code">404</div>
        <h1 class="error-title">Oups ! Perdu ?</h1>
        <p class="error-text">Le Jean-Michel que vous cherchez n'existe pas ou a été déplacé vers une autre dimension.</p>
        <a href="{{ path('home') }}" class="btn-home">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" style="width:18px;">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
            RETOUR À LA MAISON
        </a>
    </div>
</div>
{% endblock %}
