<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}jean-michel.io{% endblock %}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Host+Grotesk:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/app.css">
    <link rel="apple-touch-icon" sizes="180x180" href="/favicons/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicons/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicons/favicon-16x16.png">
    <link rel="manifest" href="/favicons/site.webmanifest">
    {% block stylesheets %}{% endblock %}
</head>
<body>
    <div class="intro-overlay">
        <div class="intro-shape">
            <div class="intro-content">
                <div class="intro-logo">
                    {% include 'components/atoms/logo.html.twig' %}
                </div>
                {% include 'components/atoms/signature.html.twig' %}
            </div>
        </div>
    </div>

    {% block body %}{% endblock %}
    
    <script>
        window.I18N = {
            'search.empty_query': "{{ 'On recrute des freelances, pas des devinettes.'|trans|e('js') }}",
            'search.no_results': "{{ 'Aucun résultat pour « {query} »'|trans|e('js') }}",
            'search.total_count': "{{ '{count} freelance{plural} · Page {page}/{total}'|trans|e('js') }}",
            'search.error': "{{ 'Erreur de connexion au serveur.'|trans|e('js') }}",
            'drawer.recruit': "{{ 'Recruter ce talent'|trans|e('js') }}",
            'drawer.compare_add': "{{ 'Comparer ce profil'|trans|e('js') }}",
            'drawer.compare_remove': "{{ 'Retirer du comparateur'|trans|e('js') }}",
            'drawer.matching_label': "{{ 'PROFILS SIMILAIRES'|trans|e('js') }}",
            'compare.limit_reached': "{{ 'Maximum 3 profils'|trans|e('js') }}",
            'compare.loading': "{{ 'Chargement de l\'analyse comparative...'|trans|e('js') }}",
            'compare.section_skills': "{{ 'Analyse des compétences'|trans|e('js') }}",
            'compare.section_bio': "{{ 'Bio & Parcours'|trans|e('js') }}",
            'compare.no_bio': "{{ 'Aucune description disponible.'|trans|e('js') }}",
            'generic.anonymous': "{{ 'Anonyme'|trans|e('js') }}",
            'generic.loading': "{{ 'Chargement...'|trans|e('js') }}",
            'generic.all_freelances': "{{ 'Tous les freelances'|trans|e('js') }}",
            'generic.freelance': "{{ 'Freelance'|trans|e('js') }}",
            'generic.results': "{{ '{count} résultat{plural}'|trans|e('js') }}",
            'generic.close': "{{ 'Fermer'|trans|e('js') }}",
            'generic.meta_text': "{{ 'La communauté freelance tech'|trans|e('js') }}",
            'email.subject': "{{ 'email.subject'|trans|e('js') }}",
            'email.body': "{{ 'email.body_content'|trans|e('js') }}",
            'toast.link_copied': "{{ 'Lien copié dans le presse-papiers'|trans|e('js') }}",
            'toast.exit_refused': "{{ 'Jean-Michel refuse de fermer.'|trans|e('js') }}",
            'context.inspect_page': "{{ 'Inspecter la page'|trans|e('js') }}",
            'context.recruit': "{{ 'Recruter un Jean-Michel'|trans|e('js') }}",
            'context.share': "{{ 'Partager le lien'|trans|e('js') }}",
            'context.exit': "{{ 'Quitter le site'|trans|e('js') }}"
        };
        function trans(key, params = {}) {
            let msg = window.I18N[key] || key;
            for (const [k, v] of Object.entries(params)) {
                msg = msg.replace(`{${k}}`, v);
            }
            return msg;
        }
    </script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
    <script src="/js/app.js"></script>
    {% block javascripts %}{% endblock %}
</body>
</html>
