{% extends 'base.html.twig' %}
{% block title %}jean-michel.io — Freelances tech{% endblock %}

{% block body %}
    <div class="app-shell">
        <!-- SIDEBAR -->
        {% embed 'components/organisms/sidebar.html.twig' %}
            {% block sidebar_content %}
                <div class="search-field-wrap">
                    <div class="results__field">
                        <div class="autocomplete-wrapper">
                            <input
                                type="text"
                                class="results__input"
                                id="searchInput"
                                placeholder="Rechercher un Jean-Michel..."
                                autocomplete="off"
                            />
                            <span id="searchSuggestion" class="search-suggestion"></span>
                        </div>
                        <button class="results__btn" id="searchBtn">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                                <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/>
                            </svg>
                        </button>
                    </div>
                    <div class="search-tip" id="searchTip"></div>
                </div>

                <div class="filter-group">
                    <p class="filter-label">JEAN-MICHEL KATÉGORI</p>
                    <div class="results__filters">
                        <button class="filter-tag active" data-query="">Tous</button>
                        <button class="filter-tag" data-query="Développeur">Développeur</button>
                        <button class="filter-tag" data-query="Data">Data</button>
                        <button class="filter-tag" data-query="DevOps">DevOps</button>
                        <button class="filter-tag" data-query="Architecte">Architecte</button>
                    </div>
                </div>

                <div class="filter-group">
                    <p class="filter-label">Trier les Jean-Michel</p>
                    <div class="results__sort-wrap">
                        <select id="sortSelect">
                            <option value="">Pertinence</option>
                            <option value="name_asc">Nom A → Z</option>
                            <option value="name_desc">Nom Z → A</option>
                        </select>
                    </div>
                </div>

                <div class="filter-group filter-group--api">
                    <a href="{{ path('app_documentation_api') }}" class="btn-api-doc">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
                        </svg>
                        DOCUMENTATION API
                    </a>
                </div>
            {% endblock %}
        {% endembed %}

        <!-- MAIN VIEW -->
        <main class="main-view">
            {% include 'components/molecules/main_header.html.twig' with {
                'id': 'resultsHeader',
                'query_id': 'resultsQuery',
                'query_text': 'Tous les freelances',
                'meta_id': 'resultsMeta',
                'meta_text': '0 freelance'
            } %}

            <div class="main-view__scroll-zone">
                <div class="results__empty" id="resultsEmpty">
                    <p class="results__empty-label">0</p>
                    <p class="results__empty-title" id="resultsEmptyText">Aucun résultat</p>
                    <span class="results__empty-sub">Essayez un autre terme.</span>
                </div>

                <div class="results__grid" id="resultsGrid">
                    <!-- Cards here -->
                </div>
            </div>

            <footer class="main-view__footer">
                <div class="results__pagination" id="resultsPagination">
                    <!-- Pagination here -->
                </div>
            </footer>
        </main>

        {% include 'components/molecules/drawer.html.twig' %}
        {% include 'components/molecules/context_menu.html.twig' %}
    </div>
{% endblock %}

{% block javascripts %}
<script src="/js/search.js"></script>
{% endblock %}
